# BuPlace Agent Configuration
# Save this as: config/siteminder.env
# IMPORTANT: Add config/ to your .gitignore — never commit this file

# ── HOTEL INFO ──────────────────────────────────────────────────────────────────
HOTEL_LOCATION=Bangkok, Thailand
STAR_RATING=4-star boutique
OWNER_EMAIL=you@buplace.com

# ── PRICING MODE ────────────────────────────────────────────────────────────────
# "approval" = Claude emails you proposed rates, waits for your APPROVE reply
# "auto"     = Claude applies rates directly to SiteMinder without asking
APPROVAL_MODE=approval

# ── ROOM BASE PRICES (USD) ──────────────────────────────────────────────────────
BASE_STANDARD=120
BASE_DELUXE=162
BASE_SUITE=252

# ── PRICE FLOORS (never go below these) ─────────────────────────────────────────
FLOOR_STANDARD=80
FLOOR_DELUXE=108
FLOOR_SUITE=170

# ── PRICE CEILINGS (never exceed these) ─────────────────────────────────────────
CEIL_STANDARD=280
CEIL_DELUXE=380
CEIL_SUITE=600

# ── COMPETITORS (comma-separated hotel names) ────────────────────────────────────
COMPETITORS=Hotel A, Hotel B, Hotel C

# ── AIRPORTS (IATA codes, comma-separated) ───────────────────────────────────────
AIRPORTS=BKK, DMK

# ── SITEMINDER CREDENTIALS ──────────────────────────────────────────────────────
SITEMINDER_URL=https://app.siteminder.com
SITEMINDER_USER=your_siteminder_email@example.com
SITEMINDER_PASS=your_siteminder_password

# ── ANTHROPIC ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
